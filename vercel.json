{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat.ts"
    },
    {
      "source": "/api/trpc/(.*)",
      "destination": "/api/trpc.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
